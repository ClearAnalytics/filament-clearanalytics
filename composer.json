{
    "name": "clearanalytics/filament-clearanalytics",
    "description": "ClearAnalytics.eu analytics widgets and dashboard for Filament v5 panels.",
    "keywords": [
        "clearanalytics",
        "filament",
        "filamentphp",
        "analytics",
        "laravel",
        "dashboard",
        "widgets"
    ],
    "homepage": "https://github.com/ClearAnalytics/filament-clearanalytics",
    "license": "MIT",
    "authors": [
        {
            "name": "Coding Agency",
            "email": "jasper@coding.agency",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "ClearAnalytics\\Filament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ClearAnalytics\\Filament\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "ClearAnalytics\\Filament\\ClearAnalyticsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
